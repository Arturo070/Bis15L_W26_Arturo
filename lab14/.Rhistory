1. Please load the data as a new object `homerange` and have a look at the column names.
#install.packages("shiny")
library("shiny")
library("tidyverse")
library("palmerpenguins")
library("janitor")
#runExample("04_mpg")
names(penguins)
penguins %>%
ggplot(aes(x=bill_length_mm, y=body_mass_g))+
geom_point(na.rm = T)
homerange %>%
ggplot(aes(x=locomotion, fill=trophic_guild))+
geom_bar(ositiin="dodge")
homerange <- read.csv("data/Tamburelloetal_HomeRangeDatabase.csv")
homerange %>%
ggplot(aes(x=locomotion, fill=trophic_guild))+
geom_bar(position="dodge")
homerange %>%
ggplot(aes(x=locomotion, fill=trophic_guild))+
geom_bar(position="dodge")
