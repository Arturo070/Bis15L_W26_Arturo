heartrate <- read_csv("data/heartrate.csv")
heartrate
heartrate %>%
ggplot(patient, mapping=aes(x=patient))
heartrate %>%
pivot_longer(-patient,
names_to = "drug",
values_to = "heartrate")
heartrate_long <- heartrate %>%
pivot_longer(-patient,
names_to = "drug",
values_to = "heartrate")
heartrate_long %>%
filter(patient=="Margaret") %>%
ggplot(aes(x=drug, y=heartrate))+
geom_col()
